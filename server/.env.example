# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/<database-name>?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB_NAME=jbm-electro-ventures

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=2d
JWT_ISSUER=
JWT_AUDIENCE=
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=30
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_FETCH_TIMEOUT_MS=10000

# Frontend
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
PUBLIC_APP_URL=http://localhost:5173

# Orders
MEMBER_DISCOUNT_RATE=0.40

# Payments
# Use "manual" for reference-number payments, or "paymongo" for GCash checkout sessions.
PAYMENT_GATEWAY=paymongo
PAYMONGO_SECRET_KEY=sk_test_your_paymongo_secret_key
PAYMONGO_PUBLIC_KEY=pk_test_your_paymongo_public_key
PAYMENT_FETCH_TIMEOUT_MS=15000

# Email notifications
APP_NAME=JBM Electro Ventures
MAIL_FROM=JBM Electro Ventures <your-email@gmail.com>
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password
ADMIN_EMAIL=admin@example.com
EMAIL_OTP_TTL_MINUTES=10
PASSWORD_RESET_TTL_MINUTES=30
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=20000
