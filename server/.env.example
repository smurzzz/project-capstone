# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/<database-name>?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB_NAME=jbm-electro-ventures

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=2d
JWT_ISSUER=
JWT_AUDIENCE=
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=30
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_FETCH_TIMEOUT_MS=10000

# Frontend
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
PUBLIC_APP_URL=http://localhost:5173

# Orders
MEMBER_DISCOUNT_RATE=0.10

# Payments
# Use "manual" for reference-number payments, or "paymongo" for checkout sessions.
PAYMENT_GATEWAY=manual
PAYMONGO_SECRET_KEY=sk_test_your_paymongo_secret_key
PAYMENT_FETCH_TIMEOUT_MS=15000

# Email notifications
MAIL_FROM=JBM Electro Ventures <no-reply@example.com>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=20000
